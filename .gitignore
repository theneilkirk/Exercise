############################
# Personal / sensitive data
############################

# FIT files and ZIP exports
*.fit
*.FIT
*.fit.zip
*.FIT.zip

# Specific folders containing FIT files
# Ignore folder contents, but keep the directory structure in Git via `.gitkeep`.
data/raw/garmin_fit_archive/*
!data/raw/garmin_fit_archive/.gitkeep
data/raw/garmin_fit_inbox/*
!data/raw/garmin_fit_inbox/.gitkeep

# Workspace / extraction temp (same pattern: keep `.gitkeep`)
data/work/*
!data/work/.gitkeep
data/work/tmp_extract/*

# Databases (do not commit actual DBs)
*.db
*.sqlite
*.sqlite3
*.db3

# Specific app database
db/training.db

# Database backups / dumps
*.sql
*.sql.gz
*.dump
*.bak

